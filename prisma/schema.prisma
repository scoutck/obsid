generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Note {
  id        String   @id @default(uuid())
  title     String   @default("")
  content   String   @default("")
  tags      String   @default("[]")
  type      String   @default("")
  links     String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Collection {
  id        String   @id @default(uuid())
  name      String
  filter    String
  createdAt DateTime @default(now())
}
