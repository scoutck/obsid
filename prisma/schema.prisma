generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Note {
  id               String   @id @default(uuid())
  title            String   @default("")
  content          String   @default("")
  tags             String   @default("[]")
  type             String   @default("")
  links            String   @default("[]")
  unresolvedPeople String   @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Collection {
  id        String   @id @default(uuid())
  name      String
  filter    String
  createdAt DateTime @default(now())
}

model PersonMeta {
  id        String   @id @default(uuid())
  noteId    String   @unique
  aliases   String   @default("[]")
  role      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NotePerson {
  noteId       String
  personNoteId String

  @@id([noteId, personNoteId])
}

model Command {
  id           String   @id @default(uuid())
  noteId       String
  line         Int
  instruction  String
  confirmation String   @default("")
  status       String   @default("pending")
  createdAt    DateTime @default(now())

  @@index([noteId])
}
