generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Note {
  id               String   @id @default(uuid())
  title            String   @default("")
  content          String   @default("")
  summary          String   @default("")
  tags             String   @default("[]")
  type             String   @default("")
  links            String   @default("[]")
  unresolvedPeople String   @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Collection {
  id        String   @id @default(uuid())
  name      String
  filter    String
  createdAt DateTime @default(now())
}

model PersonMeta {
  id          String   @id @default(uuid())
  noteId      String   @unique
  aliases     String   @default("[]")
  role        String   @default("")
  summary     String   @default("")
  userContext String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NotePerson {
  noteId       String
  personNoteId String
  highlight    String @default("")

  @@id([noteId, personNoteId])
}

model Command {
  id           String   @id @default(uuid())
  noteId       String
  line         Int
  instruction  String
  confirmation String   @default("")
  status       String   @default("pending")
  createdAt    DateTime @default(now())

  @@index([noteId])
}

model Embedding {
  id        String   @id @default(uuid())
  noteId    String   @unique
  vector    Bytes
  model     String
  updatedAt DateTime @updatedAt
}

model Conversation {
  id        String   @id @default(uuid())
  title     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  role           String
  content        String   @default("")
  toolCalls      String   @default("[]")
  createdAt      DateTime @default(now())

  @@index([conversationId])
}

model PendingPerson {
  id                   String   @id @default(uuid())
  name                 String
  sourceNoteId         String?
  sourceConversationId String?
  context              String   @default("")
  status               String   @default("pending")
  createdAt            DateTime @default(now())
}

model Task {
  id           String    @id @default(uuid())
  title        String
  completed    Boolean   @default(false)
  dueDate      DateTime?
  noteId       String?
  personNoteId String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([noteId])
  @@index([personNoteId])
  @@index([completed])
}

model UserInsight {
  id           String   @id @default(uuid())
  category     String
  content      String
  evidence     String   @default("")
  sourceNoteId String?
  source       String   @default("organize")
  createdAt    DateTime @default(now())

  @@index([category])
  @@index([sourceNoteId])
  @@index([source])
}

model NoteThinkTriage {
  id        String   @id @default(uuid())
  noteId    String   @unique
  worthy    Boolean
  reason    String   @default("")
  triagedAt DateTime @default(now())

  @@index([noteId])
}
